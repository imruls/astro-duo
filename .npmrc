# pnpm hardened configuration
# https://pnpm.io/npmrc

# Enforce engines field (Node + pnpm version)
engine-strict=true

# Let pnpm self-manage its version from the packageManager field in package.json
# (works alongside the integrity hash for tamper protection)
manage-package-manager-versions=true

# Refuse to install if the lockfile is out of sync (catches tampering & supply chain drift)
# Override locally with --no-frozen-lockfile only when intentionally updating deps.
frozen-lockfile=true

# Verify package tarball integrity against the lockfile before linking
verify-store-integrity=true

# Block lifecycle scripts by default; only packages listed in
# pnpm-workspace.yaml -> allowBuilds are allowed to run install hooks.
# Protects against malicious postinstall scripts in transitive deps.
ignore-scripts=false

# Use the official pnpm registry over HTTPS only
registry=https://registry.npmjs.org/

# Resolve peers strictly so silent version mismatches are caught at install time
strict-peer-dependencies=false
auto-install-peers=true

# Use the isolated node_modules layout (default in pnpm) — prevents phantom deps
node-linker=isolated

# Save exact versions on add (no caret ranges sneaking in unexpected upgrades)
save-exact=false
save-prefix=^

# Reject installs from non-HTTPS registries
strict-ssl=true
