---

<section class="planes" id="planes">
  <div class="container">
    <!-- Header -->
    <div class="planes__header reveal">
      <span class="section-label">Nuestros planes</span>
      <h2 class="section-title">El plan perfecto para <span>tu marca</span></h2>
      <p class="section-subtitle">
        Elegí el plan que mejor se adapte a tus necesidades y llevá tu negocio
        al siguiente nivel.
      </p>
      <div class="plan-toggle" role="tablist" aria-label="Moneda de pago">
        <button class="active" role="tab" aria-selected="true">Pesos</button>
        <button role="tab" aria-selected="false">Dolares</button>
      </div>
    </div>

    <!-- Cards -->
    <div class="plans-grid">
      {
        plans.map((plan, i) => (
          <div
            class:list={[
              "plan-card",
              "reveal",
              `reveal-delay-${i + 1}`,
              { featured: plan.featured },
            ]}
            data-price={plan.price}
            data-price-usd={plan.priceUsd}
          >
            <h3 class="plan-card__name">{plan.name}</h3>

            <div class="plan-card__price">
              <span class="plan-card__currency">$</span>
              <span class="plan-card__amount">{plan.price}</span>
              <span class="plan-card__period">/mes</span>
            </div>

            <ul class="plan-card__features">
              {plan.features.map((f) => (
                <li>
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    aria-hidden="true"
                  >
                    <polyline points="20 6 9 17 4 12" />
                  </svg>
                  {f.text}
                </li>
              ))}
            </ul>

          </div>
        ))
      }
    </div>

    <p class="planes__cta reveal">
      Por planes personalizados, servicios extras y promociones <span>ponete en contacto con nosotras!</span>
    </p>

    <div class="planes__whatsapp reveal">
      <a
        href="https://wa.me/5491100000000"
        target="_blank"
        rel="noopener noreferrer"
        class="planes__whatsapp-btn"
      >
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Contactanos por WhatsApp
      </a>
    </div>

  </div>
</section>

<style>
  .planes {
    padding: var(--space-2xl) 0;
    background: var(--white);
  }

  .planes__header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .planes__header .section-subtitle {
    margin-inline: auto;
  }

  /* Toggle */
  .plan-toggle {
    display: inline-flex;
    background: var(--cream);
    border-radius: var(--radius-full);
    padding: 4px;
    margin-top: var(--space-md);
  }

  .plan-toggle button {
    padding: 0.6rem 1.5rem;
    border-radius: var(--radius-full);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-dark);
    transition: var(--transition);
  }

  .plan-toggle button.active {
    background: var(--olive);
    color: var(--white);
    box-shadow: 0 2px 10px rgba(123, 139, 62, 0.3);
  }

  /* Grid */
  .plans-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }

  /* Card */
  .plan-card {
    background: var(--white);
    border: 1.5px solid var(--cream);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    position: relative;
    transition: var(--transition);
    overflow: hidden;
    text-align: center;
  }

  .plan-card:hover {
    border-color: var(--olive);
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.06);
  }

  .plan-card.featured {
    border-color: var(--olive);
    background: linear-gradient(
      180deg,
      var(--cream-light) 0%,
      var(--white) 100%
    );
  }

  .plan-card.featured::before {
    content: "Más popular";
    position: absolute;
    top: 1rem;
    right: 1rem;
    padding: 0.3rem 0.8rem;
    background: var(--olive);
    color: var(--white);
    font-size: 0.7rem;
    font-weight: 600;
    border-radius: var(--radius-full);
    letter-spacing: 0.02em;
  }

  .plan-card__name {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-dark);
    margin-bottom: var(--space-md);
  }

  /* Price */
  .plan-card__price {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 0.25rem;
    margin-bottom: var(--space-md);
  }

  .plan-card__currency {
    font-size: 1rem;
    font-weight: 600;
    color: var(--olive);
  }

  .plan-card__amount {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--olive);
    line-height: 1;
  }

  .plan-card__period {
    font-size: 0.85rem;
    color: var(--text-light);
  }

  /* Features */
  .plan-card__features {
    margin-bottom: var(--space-md);
    text-align: left;
  }

  .plan-card__features li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    padding: 0.5rem 0;
    font-size: 0.9rem;
    color: var(--text-dark);
  }

  .plan-card__features li svg {
    width: 18px;
    height: 18px;
    color: var(--olive);
    flex-shrink: 0;
    margin-top: 2px;
  }

  /* WhatsApp CTA */
  .planes__whatsapp {
    margin-top: var(--space-md);
    text-align: center;
  }

  .planes__whatsapp-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.9rem 2rem;
    background: var(--olive);
    color: var(--white);
    font-size: 0.95rem;
    font-weight: 600;
    border-radius: var(--radius-full);
    transition: var(--transition);
    box-shadow: 0 4px 20px rgba(123, 139, 62, 0.3);
  }

  .planes__whatsapp-btn:hover {
    background: var(--olive-dark);
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(123, 139, 62, 0.4);
  }

  .planes__whatsapp-btn svg {
    width: 20px;
    height: 20px;
  }

  /* CTA */
  .planes__cta {
    margin-top: var(--space-xl);
    text-align: center;
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-dark);
    max-width: 640px;
    margin-inline: auto;
    line-height: 1.6;
  }

  .planes__cta span {
    color: var(--olive);
    font-weight: 600;
  }

  /* Breakpoints */
  @media (min-width: 640px) {
    .plans-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .plans-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>

<script>
  const toggleBtns = document.querySelectorAll(".plan-toggle button");
  const cards = document.querySelectorAll<HTMLElement>(".plan-card");

  toggleBtns.forEach((btn, index) => {
    btn.addEventListener("click", () => {
      toggleBtns.forEach((b) => {
        b.classList.remove("active");
        b.setAttribute("aria-selected", "false");
      });
      btn.classList.add("active");
      btn.setAttribute("aria-selected", "true");

      const isUsd = index === 1;
      cards.forEach((card) => {
        const amount = card.querySelector(".plan-card__amount");
        const currency = card.querySelector(".plan-card__currency");
        if (amount && currency) {
          if (isUsd) {
            amount.textContent = card.dataset.priceUsd ?? "";
            currency.textContent = "USD";
          } else {
            amount.textContent = card.dataset.price ?? "";
            currency.textContent = "$";
          }
        }
      });
    });
  });
</script>
