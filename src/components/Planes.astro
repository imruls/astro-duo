---
interface PlanFeature {
  text: string;
}

interface Plan {
  name: string;
  price: string;
  priceUsd: string;
  featured?: boolean;
  features: PlanFeature[];
}

const plans: Plan[] = [
  {
    name: "Basic",
    price: "200.000",
    priceUsd: "140",
    features: [
      { text: "Optimización de perfil + biografía profesional" },
      {
        text: "8 Publicaciones mensuales (2 reels, 6 carruseles/post estático)",
      },
      { text: "6 Historias mensuales" },
      { text: "Planificación + calendario mensual" },
      { text: "Diseño y copywriting" },
      { text: "Reporte de métricas trimestral" },
      { text: "Uso de imágenes provistas por la marca" },
      { text: "Carpeta compartida en Google Drive" },
      { text: "Mini guía de identidad (colores + tipografías)" },
    ],
  },
  {
    name: "Medium",
    price: "320.000",
    priceUsd: "220",
    featured: true,
    features: [
      { text: "Optimización de perfil + biografía profesional" },
      {
        text: "10 Publicaciones mensuales (3 reels, 7 carruseles/post estático)",
      },
      { text: "12 Historias mensuales" },
      { text: "Planificación + calendario mensual" },
      { text: "Diseño y copywriting" },
      { text: "Reporte de métricas mensual" },
      { text: "1 grabación de contenido por 4 hs" },
      { text: "Uso de imágenes provistas por la marca" },
      { text: "Carpeta compartida en Google Drive" },
      { text: "Mini guía de identidad (colores + tipografías)" },
    ],
  },
  {
    name: "Full",
    price: "450.000",
    priceUsd: "310",
    features: [
      { text: "Optimización de perfil + biografía profesional" },
      {
        text: "12 Publicaciones mensuales (4 reels, 8 carruseles/post estático)",
      },
      { text: "20 Historias mensuales" },
      { text: "Planificación + calendario mensual" },
      { text: "Diseño y copywriting" },
      { text: "Reporte de métricas mensual" },
      { text: "1 grabación de contenido por 4 hs" },
      {
        text: "Uso de imágenes provistas por la marca + material generado en grabación",
      },
      { text: "Carpeta compartida en Google Drive" },
