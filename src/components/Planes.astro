---
/**
 * Planes — pricing section
 * Ley de Hick: 3 clear options to reduce decision fatigue
 * Efecto Von Restorff: featured plan stands out visually
 * Ley de Miller: features grouped ≤ 5 items per card
 * Efecto de posición serial: best-value plan in the center
 */

interface PlanFeature {
  text: string;
}

interface Plan {
  icon: string;
  name: string;
  description: string;
  price: string;
  featured?: boolean;
  features: PlanFeature[];
}

const plans: Plan[] = [
  {
    icon: "seed",
    name: "Semilla",
    description:
      "Ideal para emprendedores que recién comienzan su camino digital.",
    price: "29.900",
    features: [
      { text: "Gestión de 1 red social" },
      { text: "12 publicaciones mensuales" },
      { text: "Diseño de feed armónico" },
      { text: "Reporte mensual básico" },
    ],
  },
  {
    icon: "growth",
    name: "Crecimiento",
    description: "Para marcas que buscan escalar y generar comunidad activa.",
    price: "49.900",
    featured: true,
    features: [
      { text: "Gestión de 2 redes sociales" },
      { text: "20 publicaciones + 10 stories" },
      { text: "Estrategia de contenido" },
      { text: "Calendario editorial" },
      { text: "Reporte detallado + reunión" },
    ],
  },
  {
    icon: "star",
    name: "Explosión",
    description: "Todo lo que tu marca necesita para dominar el mundo digital.",
    price: "79.900",
    features: [
      { text: "Gestión de 3 redes sociales" },
      { text: "30 publicaciones + stories + reels" },
      { text: "Campañas de Ads (Meta + Google)" },
      { text: "Branding y diseño de marca" },
      { text: "Soporte prioritario 24/7" },
    ],
  },
];
---

<section class="planes" id="planes">
  <div class="container">
    <!-- Header -->
    <div class="planes__header reveal">
      <span class="section-label">Nuestros planes</span>
      <h2 class="section-title">El plan perfecto para <span>tu marca</span></h2>
      <p class="section-subtitle">
        Elegí el plan que mejor se adapte a tus necesidades y llevá tu negocio
        al siguiente nivel.
      </p>
      <div class="plan-toggle" role="tablist" aria-label="Frecuencia de pago">
        <button class="active" role="tab" aria-selected="true">Mensual</button>
        <button role="tab" aria-selected="false">Trimestral</button>
      </div>
    </div>

    <!-- Cards -->
    <div class="plans-grid">
      {
        plans.map((plan, i) => (
          <div
            class:list={[
              "plan-card",
              "reveal",
              `reveal-delay-${i + 1}`,
              { featured: plan.featured },
            ]}
          >
            <div class="plan-card__icon">
              {plan.icon === "seed" && (
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path d="M12 22c4-4 8-7.5 8-12a8 8 0 10-16 0c0 4.5 4 8 8 12z" />
                  <circle cx="12" cy="10" r="3" />
                </svg>
              )}
              {plan.icon === "growth" && (
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path d="M22 12h-4l-3 9L9 3l-3 9H2" />
                </svg>
              )}
              {plan.icon === "star" && (
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                </svg>
              )}
            </div>

            <h3 class="plan-card__name">{plan.name}</h3>
            <p class="plan-card__desc">{plan.description}</p>

            <div class="plan-card__price">
              <span class="plan-card__currency">$</span>
              <span class="plan-card__amount">{plan.price}</span>
              <span class="plan-card__period">/mes</span>
            </div>

            <ul class="plan-card__features">
              {plan.features.map((f) => (
                <li>
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    aria-hidden="true"
                  >
                    <polyline points="20 6 9 17 4 12" />
                  </svg>
                  {f.text}
                </li>
              ))}
            </ul>

            <button class="plan-card__btn">Elegir plan</button>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .planes {
    padding: var(--space-2xl) 0;
    background: var(--white);
  }

  .planes__header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .planes__header .section-subtitle {
    margin-inline: auto;
  }

  /* Toggle */
  .plan-toggle {
    display: inline-flex;
    background: var(--cream);
    border-radius: var(--radius-full);
    padding: 4px;
    margin-top: var(--space-md);
  }

  .plan-toggle button {
    padding: 0.6rem 1.5rem;
    border-radius: var(--radius-full);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-muted);
    transition: var(--transition);
  }

  .plan-toggle button.active {
    background: var(--olive);
    color: var(--white);
    box-shadow: 0 2px 10px rgba(123, 139, 62, 0.3);
  }

  /* Grid */
  .plans-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }

  /* Card */
  .plan-card {
    background: var(--white);
    border: 1.5px solid var(--cream);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    position: relative;
    transition: var(--transition);
    overflow: hidden;
  }

  .plan-card:hover {
    border-color: var(--olive);
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.06);
  }

  .plan-card.featured {
    border-color: var(--olive);
    background: linear-gradient(
      180deg,
      var(--cream-light) 0%,
      var(--white) 100%
    );
  }

  .plan-card.featured::before {
    content: "Más popular";
    position: absolute;
    top: 1rem;
    right: 1rem;
    padding: 0.3rem 0.8rem;
    background: var(--olive);
    color: var(--white);
    font-size: 0.7rem;
    font-weight: 600;
    border-radius: var(--radius-full);
    letter-spacing: 0.02em;
  }

  /* Icon */
  .plan-card__icon {
    width: 48px;
    height: 48px;
    background: rgba(123, 139, 62, 0.1);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-sm);
  }

  .plan-card__icon svg {
    width: 24px;
    height: 24px;
    color: var(--olive);
  }

  .plan-card__name {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-dark);
    margin-bottom: 0.25rem;
  }

  .plan-card__desc {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: var(--space-md);
  }

  /* Price */
  .plan-card__price {
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
    margin-bottom: var(--space-md);
  }

  .plan-card__currency {
    font-size: 1rem;
    font-weight: 600;
    color: var(--olive);
  }

  .plan-card__amount {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--olive);
    line-height: 1;
  }

  .plan-card__period {
    font-size: 0.85rem;
    color: var(--text-light);
  }

  /* Features */
  .plan-card__features {
    margin-bottom: var(--space-md);
  }

  .plan-card__features li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    padding: 0.5rem 0;
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .plan-card__features li svg {
    width: 18px;
    height: 18px;
    color: var(--olive);
    flex-shrink: 0;
    margin-top: 2px;
  }

  /* Button */
  .plan-card__btn {
    width: 100%;
    padding: 0.9rem;
    border-radius: var(--radius-full);
    font-size: 0.9rem;
    font-weight: 600;
    transition: var(--transition);
    text-align: center;
    background: transparent;
    border: 1.5px solid var(--olive);
    color: var(--olive);
  }

  .plan-card__btn:hover {
    background: var(--olive);
    color: var(--white);
  }

  .plan-card.featured .plan-card__btn {
    background: var(--olive);
    color: var(--white);
    border: none;
    box-shadow: 0 4px 20px rgba(123, 139, 62, 0.3);
  }

  .plan-card.featured .plan-card__btn:hover {
    background: var(--olive-dark);
  }

  /* Breakpoints */
  @media (min-width: 640px) {
    .plans-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .plans-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>

<script>
  const toggleBtns = document.querySelectorAll(".plan-toggle button");
  toggleBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      toggleBtns.forEach((b) => {
        b.classList.remove("active");
        b.setAttribute("aria-selected", "false");
      });
      btn.classList.add("active");
      btn.setAttribute("aria-selected", "true");
    });
  });
</script>
