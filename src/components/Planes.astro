---
import { plans, extraService } from "@data/dataSite";
---

<svg class="sr-only" aria-hidden="true">
  <symbol id="icon-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
    <polyline points="20 6 9 17 4 12" />
  </symbol>
</svg>

<section class="planes" id="planes">
  <div class="container">
    <!-- Header -->
    <div class="planes__header reveal">
      <span class="section-label">Nuestros planes</span>
      <h2 class="section-title">El plan perfecto para <span>tu marca</span></h2>
      <p class="section-subtitle">
        Elegí el plan que mejor se adapte a tus necesidades y llevá tu negocio
        al siguiente nivel.
      </p>
      <div class="plan-toggle" role="tablist" aria-label="Moneda de pago">
        <button type="button" class="active" role="tab" aria-selected="true">Pesos</button>
        <button type="button" role="tab" aria-selected="false">Dolares</button>
      </div>
    </div>

    <!-- Cards -->
    <div class="plans-grid">
      {
        plans.map((plan, i) => (
          <div
            class:list={[
              "plan-card",
              "reveal",
              `reveal-delay-${i + 1}`,
              { featured: plan.featured },
            ]}
            data-price={plan.price}
            data-price-usd={plan.priceUsd}
          >
            <h3 class="plan-card__name">{plan.name}</h3>

            <div class="plan-card__price">
              <span class="plan-card__currency">ARS</span>
              <span class="plan-card__amount">{plan.price}</span>
              <span class="plan-card__period">/mes</span>
            </div>

            <ul class="plan-card__features">
              {plan.features.map((f) => (
                <li>
                  <svg aria-hidden="true"><use href="#icon-check" /></svg>
                  {f.text}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div class="planes__extra-banner reveal">
      <!-- Col 1: Servicio -->
      <div class="extra-banner__info">
        <span class="extra-banner__badge">Servicio adicional</span>
        <h3 class="extra-banner__title">Campañas + Paid Media</h3>
        <p class="extra-banner__desc">
          Gestionamos tus campañas publicitarias de principio a fin: estrategia,
          segmentación, creatividades y optimización continua.
        </p>
      </div>

      <!-- Col 2: Precio -->
      <div
        class="extra-banner__pricing"
        data-price={extraService.price}
        data-price-usd={extraService.priceUsd}
      >
        <span class="extra-banner__pricing-label">Gestión del servicio</span>
        <div class="extra-banner__price">
          <span class="extra-banner__currency">ARS</span>
          <span class="extra-banner__amount">{extraService.price}</span>
        </div>
      </div>

      <!-- Col 3: Nota -->
      <div class="extra-banner__note">
        <svg
          class="extra-banner__note-icon"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="10"></circle>
          <line x1="12" y1="16" x2="12" y2="12"></line>
          <line x1="12" y1="8" x2="12.01" y2="8"></line>
        </svg>
        <p>
          El presupuesto destinado a la pauta publicitaria
          <strong>corre por cuenta del cliente</strong> y no está incluido en este
          valor.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .planes {
    padding: var(--space-2xl) 0;
    background: var(--white);
  }

  .planes__header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .planes__header .section-subtitle {
    margin-inline: auto;
  }

  /* Toggle */
  .plan-toggle {
    display: inline-flex;
    background: var(--cream);
    border-radius: var(--radius-full);
    padding: 4px;
    margin-top: var(--space-md);
  }

  .plan-toggle button {
    padding: 0.6rem 1.5rem;
    border-radius: var(--radius-full);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-dark);
    transition: var(--transition);
  }

  .plan-toggle button.active {
    background: var(--olive);
    color: var(--white);
    box-shadow: 0 2px 10px rgba(123, 139, 62, 0.3);
  }

  /* Grid */
  .plans-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }

  /* Card */
  .plan-card {
    background: var(--white);
    border: 1.5px solid var(--cream);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    position: relative;
    transition: var(--transition);
    overflow: hidden;
    text-align: center;
    will-change: transform;
  }

  .plan-card:hover {
    border-color: var(--olive);
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.06);
  }

  .plan-card.featured {
    border-color: var(--olive);
    background: linear-gradient(
      180deg,
      var(--cream-light) 0%,
      var(--white) 100%
    );
  }

  .plan-card.featured::before {
    content: "Más popular";
    position: absolute;
    top: 1rem;
    right: 1rem;
    padding: 0.3rem 0.8rem;
    background: var(--olive);
    color: var(--white);
    font-size: 0.7rem;
    font-weight: 600;
    border-radius: var(--radius-full);
    letter-spacing: 0.02em;
  }

  .plan-card__name {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-dark);
    margin-bottom: var(--space-md);
  }

  /* Price */
  .plan-card__price {
    display: flex;
    align-items: baseline;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.25rem;
    margin-bottom: var(--space-md);
  }

  .plan-card__currency {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--olive);
  }

  .plan-card__amount {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--olive);
    line-height: 1;
  }

  .plan-card__period {
    font-size: 0.85rem;
    color: var(--text-light);
  }

  /* Features */
  .plan-card__features {
    margin-bottom: var(--space-md);
    text-align: left;
  }

  .plan-card__features li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    padding: 0.5rem 0;
    font-size: 0.9rem;
    color: var(--text-dark);
  }

  .plan-card__features li svg {
    width: 18px;
    height: 18px;
    color: var(--olive);
    flex-shrink: 0;
    margin-top: 2px;
  }

  /* Extra Service Banner */
  .planes__extra-banner {
    margin-top: var(--space-xl);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
    padding: var(--space-lg);
    background: var(--olive);
    border-radius: var(--radius-lg);
    overflow: hidden;
    position: relative;
  }

  .planes__extra-banner::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at 60% 50%,
      rgba(255, 255, 255, 0.08) 0%,
      transparent 70%
    );
    pointer-events: none;
  }

  /* Col 1 - Info */
  .extra-banner__info {
    position: relative;
  }

  .extra-banner__badge {
    display: inline-block;
    padding: 0.3rem 0.8rem;
    background: var(--white);
    color: var(--olive-dark);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border-radius: var(--radius-full);
    margin-bottom: var(--space-sm);
  }

  .extra-banner__title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 0.5rem;
  }

  .extra-banner__desc {
    font-size: 0.85rem;
    color: var(--cream);
    line-height: 1.6;
    max-width: 380px;
  }

  /* Col 2 - Pricing */
  .extra-banner__pricing {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 0.25rem;
  }

  .extra-banner__pricing-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--cream);
  }

  .extra-banner__price {
    display: flex;
    align-items: baseline;
    gap: 0.35rem;
  }

  .extra-banner__currency {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--cream);
  }

  .extra-banner__amount {
    font-size: 2.25rem;
    font-weight: 700;
    color: var(--white);
    line-height: 1;
  }

  /* Col 3 - Note */
  .extra-banner__note {
    position: relative;
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    padding: var(--space-sm);
    background: rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-sm);
    border-left: 2px solid var(--cream);
  }

  .extra-banner__note-icon {
    width: 18px;
    height: 18px;
    color: var(--cream);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .extra-banner__note p {
    font-size: 0.8rem;
    color: var(--cream);
    line-height: 1.5;
  }

  .extra-banner__note strong {
    color: var(--white);
    font-weight: 600;
  }

  @media (min-width: 768px) {
    .planes__extra-banner {
      grid-template-columns: 1.2fr auto 1fr;
      align-items: center;
      padding: var(--space-lg) var(--space-xl);
    }

    .extra-banner__pricing {
      padding-inline: var(--space-lg);
      border-left: 1px solid rgba(255, 255, 255, 0.2);
      border-right: 1px solid rgba(255, 255, 255, 0.2);
    }
  }

  /* Breakpoints */
  @media (min-width: 640px) {
    .plans-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .plans-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>

<script>
  const toggleBtns = document.querySelectorAll(".plan-toggle button");
  const cards = document.querySelectorAll<HTMLElement>(".plan-card");
  const bannerPricing = document.querySelector<HTMLElement>(
    ".extra-banner__pricing",
  );

  toggleBtns.forEach((btn, index) => {
    btn.addEventListener("click", () => {
      toggleBtns.forEach((b) => {
        b.classList.remove("active");
        b.setAttribute("aria-selected", "false");
      });
      btn.classList.add("active");
      btn.setAttribute("aria-selected", "true");

      const isUsd = index === 1;
      cards.forEach((card) => {
        const amount = card.querySelector(".plan-card__amount");
        const currency = card.querySelector(".plan-card__currency");
        if (amount && currency) {
          if (isUsd) {
            amount.textContent = card.dataset.priceUsd ?? "";
            currency.textContent = "USD";
          } else {
            amount.textContent = card.dataset.price ?? "";
            currency.textContent = "ARS";
          }
        }
      });

      if (bannerPricing) {
        const bannerAmount = bannerPricing.querySelector(
          ".extra-banner__amount",
        );
        const bannerCurrency = bannerPricing.querySelector(
          ".extra-banner__currency",
        );
        if (bannerAmount && bannerCurrency) {
          if (isUsd) {
            bannerAmount.textContent = bannerPricing.dataset.priceUsd ?? "";
            bannerCurrency.textContent = "USD";
          } else {
            bannerAmount.textContent = bannerPricing.dataset.price ?? "";
            bannerCurrency.textContent = "ARS";
          }
        }
      }
    });
  });
</script>
