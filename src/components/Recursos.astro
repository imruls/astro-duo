---
/**
 * Recursos — free resources grid
 * Ley de Similitud: consistent card design across items
 * Ley de Proximidad: grouped info in each card
 * Ley de Región Común: cards act as clear visual containers
 */

interface Recurso {
  tag: string;
  bgClass: string;
  iconPath: string;
  title: string;
  excerpt: string;
  linkText: string;
}

const recursos: Recurso[] = [
  {
    tag: "Guía",
    bgClass: "bg-1",
    iconPath:
      "M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z",
    title: "Cómo crear contenido que conecte",
    excerpt:
      "Aprendé a comunicar tu esencia de marca a través de contenido auténtico que genera comunidad.",
    linkText: "Leer más",
  },
  {
    tag: "Template",
    bgClass: "bg-2",
    iconPath:
      "M3 3h18v18H3zM8.5 8.5a1.5 1.5 0 100-3 1.5 1.5 0 000 3zM21 15l-5-5L5 21",
    title: "Pack de plantillas para Instagram",
    excerpt:
      "Plantillas editables para stories, posts y reels que mantienen la coherencia visual de tu marca.",
    linkText: "Descargar",
  },
  {
    tag: "Checklist",
    bgClass: "bg-3",
    iconPath: "M12 20V10M18 20V4M6 20v-4",
    title: "Auditoría express de redes sociales",
    excerpt:
      "Una checklist completa para evaluar y optimizar el rendimiento de tus perfiles en redes.",
    linkText: "Obtener",
  },
  {
    tag: "Video",
    bgClass: "bg-4",
    iconPath:
      "M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10zM10 8l6 4-6 4V8z",
    title: "Masterclass: Ads para principiantes",
    excerpt:
      "Aprendé a configurar tu primera campaña publicitaria en Meta Ads paso a paso.",
    linkText: "Ver ahora",
  },
];
---

<section class="recursos" id="recursos">
  <div class="container">
    <div class="recursos__header reveal">
      <span class="section-label">Recursos</span>
      <h2 class="section-title">Herramientas para <span>crecer</span></h2>
      <p class="section-subtitle">
        Contenido gratuito para que puedas seguir aprendiendo y mejorando tu
        presencia digital.
      </p>
    </div>

    <div class="recursos__grid">
      {
        recursos.map((r, i) => (
          <article
            class:list={["recurso-card", "reveal", `reveal-delay-${i + 1}`]}
          >
            <div class="recurso-card__image">
              <div class:list={["recurso-card__bg", r.bgClass]}>
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  aria-hidden="true"
                >
                  <path d={r.iconPath} />
                </svg>
              </div>
              <span class="recurso-card__tag">{r.tag}</span>
            </div>
            <div class="recurso-card__body">
              <h3 class="recurso-card__title">{r.title}</h3>
              <p class="recurso-card__excerpt">{r.excerpt}</p>
              <a href="#" class="recurso-card__link">
                {r.linkText}
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  aria-hidden="true"
                >
                  <path d="M5 12h14M12 5l7 7-7 7" />
                </svg>
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .recursos {
    padding: var(--space-2xl) 0;
    background: var(--cream-light);
  }

  .recursos__header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .recursos__header .section-subtitle {
    margin-inline: auto;
  }

  .recursos__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }

  /* Card */
  .recurso-card {
    background: var(--white);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: var(--transition);
    border: 1px solid rgba(196, 185, 160, 0.2);
  }

  .recurso-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.08);
  }

  /* Image area */
  .recurso-card__image {
    height: 180px;
    position: relative;
    overflow: hidden;
  }

  .recurso-card__bg {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .recurso-card__bg svg {
    width: 48px;
    height: 48px;
    opacity: 0.6;
  }

  .bg-1 {
    background: linear-gradient(135deg, var(--olive), var(--olive-dark));
  }
  .bg-2 {
    background: linear-gradient(135deg, var(--pink-light), var(--blush));
  }
  .bg-3 {
    background: linear-gradient(135deg, var(--tan), var(--cream));
  }
  .bg-4 {
    background: linear-gradient(135deg, var(--olive-dark), var(--olive-deep));
  }

  .bg-1 svg,
  .bg-4 svg {
    color: var(--white);
  }
  .bg-2 svg {
    color: var(--olive);
  }
  .bg-3 svg {
    color: var(--olive-dark);
  }

  .recurso-card__tag {
    position: absolute;
    top: 1rem;
    left: 1rem;
    padding: 0.3rem 0.8rem;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(4px);
    border-radius: var(--radius-full);
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--olive);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Body */
  .recurso-card__body {
    padding: 1.5rem;
  }

  .recurso-card__title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-dark);
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }

  .recurso-card__excerpt {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .recurso-card__link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--olive);
    transition: var(--transition);
  }

  .recurso-card__link svg {
    width: 16px;
    height: 16px;
    transition: var(--transition);
  }

  .recurso-card__link:hover svg {
    transform: translateX(4px);
  }

  /* Breakpoints */
  @media (min-width: 640px) {
    .recursos__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .recursos__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
