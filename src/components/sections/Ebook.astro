---
import { Image } from "astro:assets";
import { ebookFeatures as features, ebookReviews as reviews } from "@data/dataSite";
import Icon from "@ui/Icon.astro";
import ebookCover from "@images/PortadaEbook.png";
---

<section class="ebook" id="ebook">
  <div class="container ebook__grid">
    <!-- Copy -->
    <div class="ebook__content reveal">
      <span class="section-label ebook__label">Nuestro Ebook</span>
      <h2 class="section-title ebook__title">
        Descargá nuestro <span>ebook</span> gratuito
      </h2>
      <p class="ebook__desc">
        El ABC de las Ventas en Redes es la guía práctica que te lleva de cero a
        tu primera campaña rentable, sin tecnicismos y con acciones concretas de
        15 minutos por capítulo.
      </p>

      <div class="ebook__features">
        {
          features.map((f) => (
            <div class="ebook__feature">
              <div class="ebook__feature-icon">
                <Icon name={f.icon as any} />
              </div>
              <span class="ebook__feature-text">{f.text}</span>
            </div>
          ))
        }
      </div>

      <a
        href="/downloads/Ebook - El ABC de las redes - Dúo Studio.pdf"
        download
        class="ebook__cta"
      >
        Descargar gratis
        <Icon name="download" />
      </a>
    </div>

    <!-- Portada -->
    <div class="ebook__mockup reveal reveal-delay-2">
      <Image
        src={ebookCover}
        alt="Portada del ebook - Guía de Marketing Digital"
        class="ebook__cover"
        widths={[200, 300, 400]}
        sizes="(min-width: 1024px) 300px, 200px"
        format="webp"
        loading="lazy"
        decoding="async"
      />
    </div>
  </div>

  <!-- Reviews carousel -->
  <div class="container ebook__reviews">
    <h3 class="ebook__reviews-title">Lo que dicen quienes lo leyeron</h3>
    <div
      class="ebook__carousel"
      role="region"
      aria-label="Reseñas del ebook"
      aria-roledescription="carousel"
    >
      <button
        class="ebook__arrow ebook__arrow--prev"
        aria-label="Reseña anterior"
      >
        <Icon name="chevron-left" size={20} />
      </button>
      <div class="ebook__track-wrapper">
        <div class="ebook__track">
          {
            reviews.map((r) => (
              <div class="ebook__review-card">
                <div class="ebook__review-stars">
                  {Array.from({ length: r.stars }).map(() => (
                    <Icon name="star" size={16} fill="currentColor" stroke="none" />
                  ))}
                </div>
                <p class="ebook__review-text">"{r.text}"</p>
                <div class="ebook__review-author">
                  <span class="ebook__review-name">{r.name}</span>
                  <span class="ebook__review-role">{r.user}</span>
                </div>
              </div>
            ))
          }
        </div>
      </div>
      <button
        class="ebook__arrow ebook__arrow--next"
        aria-label="Siguiente reseña"
      >
        <Icon name="chevron-right" size={20} />
      </button>
    </div>
  </div>
</section>

<script>
  const wrapper = document.querySelector(".ebook__track-wrapper") as HTMLElement;
  const prevBtn = document.querySelector(".ebook__arrow--prev");
  const nextBtn = document.querySelector(".ebook__arrow--next");

  if (wrapper) {
    const cardWidth = 280 + 16; // card width + gap approximation

    nextBtn?.addEventListener("click", () => {
      wrapper.scrollBy({ left: cardWidth, behavior: "smooth" });
    });

    prevBtn?.addEventListener("click", () => {
      wrapper.scrollBy({ left: -cardWidth, behavior: "smooth" });
    });
  }
</script>

<style>
  .ebook {
    padding: var(--space-2xl) 0;
    background: linear-gradient(to right, var(--pink-light), transparent);
    position: relative;
    overflow: hidden;
    contain: paint;
  }

  .ebook::before {
    content: "";
    position: absolute;
    top: -50%;
    right: -30%;
    width: 80vw;
    height: 80vw;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(255, 255, 255, 0.05) 0%,
      transparent 70%
    );
    pointer-events: none;
  }

  /* Label & title overrides for light bg */
  .ebook__label {
    color: var(--olive);
  }

  .ebook__label::before {
    background: var(--olive);
  }

  .ebook__title {
    color: var(--text-dark);
  }

  .ebook__title span {
    color: var(--olive);
  }

  .ebook__desc {
    font-size: 1rem;
    color: var(--text-dark);
    line-height: 1.7;
    max-width: 480px;
    margin-bottom: var(--space-lg);
  }

  /* Features grid */
  .ebook__features {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-sm);
    margin-bottom: var(--space-lg);
  }

  .ebook__feature {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    background: rgba(0, 0, 0, 0.05);
    border-radius: var(--radius-md);
    backdrop-filter: blur(4px);
  }

  .ebook__feature-icon {
    width: 36px;
    height: 36px;
    border-radius: var(--radius-sm);
    background: rgba(85, 107, 47, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .ebook__feature-icon svg {
    width: 18px;
    height: 18px;
    color: var(--text-dark);
  }

  .ebook__feature-text {
    font-size: 0.9rem;
    color: var(--text-dark);
  }

  /* CTA button */
  .ebook__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1rem 2rem;
    background: var(--olive);
    color: var(--white);
    border-radius: var(--radius-full);
    font-size: 0.95rem;
    font-weight: 600;
    transition: var(--transition);
    box-shadow: 0 4px 20px rgba(85, 107, 47, 0.3);
  }

  .ebook__cta:hover {
    background: var(--olive-deep);
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(85, 107, 47, 0.4);
  }

  /* Book cover */
  .ebook__mockup {
    margin-top: var(--space-xl);
    display: flex;
    justify-content: center;
  }

  .ebook__cover {
    width: 200px;
    height: auto;
    border-radius: 4px 16px 16px 4px;
    box-shadow: -6px 6px 20px rgba(0, 0, 0, 0.25);
    transform: perspective(800px) rotateY(-8deg);
    transition: var(--transition-slow);
  }

  .ebook__cover:hover {
    transform: perspective(800px) rotateY(-2deg) translateY(-8px);
  }

  /* Reviews carousel */
  .ebook__reviews {
    margin-top: var(--space-xl);
  }

  .ebook__reviews-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-dark);
    text-align: center;
    margin-bottom: var(--space-lg);
  }

  .ebook__carousel {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .ebook__arrow {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 2px solid var(--olive);
    background: transparent;
    color: var(--olive);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: var(--transition);
  }

  .ebook__arrow:hover {
    background: var(--olive);
    color: var(--white);
  }

  .ebook__track-wrapper {
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    flex: 1;
  }

  .ebook__track-wrapper::-webkit-scrollbar {
    display: none;
  }

  .ebook__track {
    display: flex;
    gap: var(--space-md);
  }

  .ebook__review-card {
    min-width: 280px;
    flex: 0 0 280px;
    scroll-snap-align: start;
    background: var(--white);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
  }

  .ebook__review-stars {
    display: flex;
    gap: 2px;
    color: #f5a623;
    margin-bottom: 0.75rem;
  }

  .ebook__review-text {
    font-size: 0.9rem;
    color: var(--text-dark);
    line-height: 1.6;
    margin-bottom: 1rem;
    font-style: italic;
  }

  .ebook__review-author {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .ebook__review-name {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-dark);
  }

  .ebook__review-role {
    font-size: 0.75rem;
    color: var(--text-light);
  }

  /* Breakpoints */
  @media (min-width: 640px) {
    .ebook__features {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .ebook__grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      align-items: center;
      gap: var(--space-xl);
    }

    .ebook__mockup {
      margin-top: 0;
      justify-content: flex-end;
    }

    .ebook__cover {
      width: 300px;
    }
  }
</style>
