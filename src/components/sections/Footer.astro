---
import { Image } from "astro:assets";
import footerLogo from "@images/5.png";
import { navLinks, socialLinks } from "@data/dataSite";
---

<footer class="footer">
  <div class="container">
    <div class="footer__top">
      <div class="footer__brand">
        <div class="footer__logo">
          <Image src={footerLogo} alt="Dúo Studio Digital" height={100} />
        </div>
        <p class="footer__tagline">
          Tu partner creativo para impulsar tu marca en el mundo digital con
          estrategia y autenticidad.
        </p>
        <p class="footer__location">Buenos Aires, Argentina</p>
      </div>

      <nav class="footer__nav" aria-label="Navegación del footer">
        <p class="footer__label section-label">Navegación</p>
        <ul class="footer__links">
          {
            navLinks.map((link) => (
              <li>
                <a href={link.href}>{link.label}</a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div class="footer__contact">
        <p class="footer__label section-label">Conectemos</p>
        <div class="footer__social">
          {
            socialLinks.map((link) => (
              <a
                href={link.href}
                target={link.external ? "_blank" : undefined}
                rel={link.external ? "noopener noreferrer" : undefined}
                aria-label={link.label}
              >
                <Fragment set:html={link.svg} />
              </a>
            ))
          }
        </div>
      </div>
    </div>

    <div class="footer__bottom">
      <p class="footer__copyright">
        &copy; {new Date().getFullYear()} Dúo Studio Digital &middot; Todos los derechos
        reservados
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--text-dark);
    color: var(--white);
    padding: var(--space-xl) 0 var(--space-lg);
    position: relative;
  }

  .footer__top {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    padding-bottom: var(--space-md);
  }

  .footer__brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-sm);
  }

  .footer__logo img {
    height: 100px;
    width: auto;
  }

  .footer__tagline {
    font-size: 0.85rem;
    line-height: 1.7;
    max-width: 400px;
    color: var(--white);
  }

  .footer__location {
    font-size: 0.8rem;
    color: var(--white);
  }

  .footer__label {
    margin-bottom: 0.75rem;
  }

  .footer__label::before {
    display: none;
  }

  .footer__nav {
    text-align: center;
  }

  .footer__links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem 1.25rem;
  }

  .footer__links a {
    font-size: 0.9rem;
    color: var(--white);
    transition: var(--transition);
  }

  .footer__links a:hover {
    color: var(--olive);
  }

  .footer__contact {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.75rem;
  }

  .footer__social {
    display: flex;
    gap: 0.75rem;
  }

  .footer__social a {
    min-width: 44px;
    min-height: 44px;
  }

  .footer__social a {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: var(--transition);
  }

  .footer__social a:hover {
    background: var(--olive);
    transform: translateY(-2px);
  }

  .footer__social a :global(svg) {
    width: 18px;
    height: 18px;
    color: var(--white);
    transition: var(--transition);
  }

  .footer__social a:hover :global(svg) {
    color: var(--text-dark);
  }

  .footer__bottom {
    padding-top: var(--space-md);
    text-align: center;
  }

  .footer__copyright {
    font-size: 0.8rem;
    color: var(--white);
  }

  /* Mobile: separators between footer groups + FAB safe area */
  @media (max-width: 767px) {
    .footer {
      padding-bottom: calc(var(--space-lg) + 4rem);
    }

    .footer__nav,
    .footer__contact {
      padding-top: var(--space-md);
      border-top: 1px solid rgba(255, 255, 255, 0.1);
    }
  }

  /* Breakpoints */
  @media (min-width: 768px) {
    .footer__top {
      grid-template-columns: 1.2fr 0.8fr 1fr;
      justify-items: center;
      gap: var(--space-lg) var(--space-md);
    }

    .footer__nav {
      text-align: left;
    }

    .footer__contact {
      align-items: flex-start;
      text-align: left;
    }

    .footer__links {
      flex-direction: column;
      justify-content: flex-start;
    }
  }
</style>
