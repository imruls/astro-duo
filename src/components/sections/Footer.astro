---
import footerLogo from "../../assets/images/5.png";
---

<footer class="footer">
  <div class="container">
    <div class="footer__top">
      <div class="footer__logo">
        <img src={footerLogo.src} alt="Dúo Studio Digital" />
      </div>

      <div class="footer__center">
        <p class="footer__tagline">
          Tu partner creativo para impulsar tu marca en el mundo digital con
          estrategia y autenticidad.
        </p>
        <p class="footer__bottom">
          &copy; {new Date().getFullYear()} Dúo Studio Digital &middot; Todos los
          derechos reservados
        </p>
      </div>

      <div class="footer__social">
        <a
          href="https://www.instagram.com/duostudio.digital/"
          target="_blank"
          aria-label="Instagram"
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37zM17.5 6.5h.01"
            ></path>
          </svg>
        </a>
        <a
          href="https://www.tiktok.com/@duo.studio.digital"
          target="_blank"
          aria-label="TikTok"
        >
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.34-6.34V8.55a8.28 8.28 0 004.76 1.51V6.69h-1z"
            ></path>
          </svg>
        </a>
        <a
          href="https://wa.me/5491173636081"
          target="_blank"
          aria-label="WhatsApp"
        >
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
            ></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--text-dark);
    color: var(--white);
    padding: var(--space-2xl) 0 var(--space-xl);
  }

  .footer__top {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-md);
  }

  .footer__logo img {
    height: 160px;
    width: auto;
  }

  .footer__center {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    text-align: center;
  }

  .footer__tagline {
    font-size: 0.85rem;
    line-height: 1.7;
  }

  .footer__social {
    display: flex;
    gap: 0.75rem;
  }

  .footer__social a {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: var(--transition);
  }

  .footer__social a:hover {
    background: var(--olive);
    transform: translateY(-2px);
  }

  .footer__social a svg {
    width: 18px;
    height: 18px;
    color: var(--white);
  }

  .footer__bottom {
    font-size: 0.8rem;
  }

  /* Breakpoints */
  @media (min-width: 768px) {
    .footer__top {
      flex-direction: row;
      align-items: center;
    }

    .footer__logo {
      flex: 1;
      text-align: left;
    }

    .footer__center {
      flex: 1;
    }

    .footer__social {
      flex: 1;
      justify-content: flex-end;
    }
  }
</style>
