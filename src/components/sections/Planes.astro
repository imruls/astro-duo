---
import { plans } from "@data/dataSite";

const MAX_VISIBLE_FEATURES = 5;
---

<svg class="sr-only" aria-hidden="true">
  <symbol
    id="icon-check"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
  >
    <polyline points="20 6 9 17 4 12"></polyline>
  </symbol>
</svg>

<section class="planes" id="planes">
  <div class="container">
    <!-- Header -->
    <div class="planes__header reveal">
      <span class="section-label">Nuestros planes</span>
      <h2 class="section-title">El plan perfecto para <span>tu marca</span></h2>
      <p class="section-subtitle">
        Elegí el plan que mejor se adapte a tus necesidades y llevá tu negocio
        al siguiente nivel.
      </p>
      <div class="plan-toggle" role="tablist" aria-label="Moneda de pago">
        <span class="plan-toggle__pill"></span>
        <button type="button" class="active" role="tab" aria-selected="true"
          >Pesos</button
        >
        <button type="button" role="tab" aria-selected="false">Dolares</button>
      </div>
    </div>

    <!-- Cards -->
    <div class="plans-grid">
      {
        plans.map((plan, i) => (
          <div
            class:list={[
              "plan-card",
              "reveal",
              `reveal-delay-${i + 1}`,
              { featured: plan.featured },
            ]}
            data-price={plan.price}
            data-price-usd={plan.priceUsd}
          >
            {plan.featured && <span class="plan-card__badge">Más popular</span>}
            <h3 class="plan-card__name">{plan.name}</h3>

            <div class="plan-card__price">
              <span class="plan-card__currency">ARS</span>
              <span class="plan-card__amount">{plan.price}</span>
              <span class="plan-card__period">/mes</span>
            </div>

            <a
              href={`https://wa.me/+5491173636081?text=${encodeURIComponent(`Hola, me interesa el plan ${plan.name}, quiero más info`)}`}
              target="_blank"
              rel="noopener noreferrer"
              class:list={[
                "plan-card__cta",
                { "plan-card__cta--featured": plan.featured },
              ]}
            >
              Elegir plan
            </a>

            <ul class="plan-card__features" data-max={MAX_VISIBLE_FEATURES}>
              {plan.features.map((f, j) => (
                <li data-index={j}>
                  <svg aria-hidden="true">
                    <use href="#icon-check" />
                  </svg>
                  {f.text}
                </li>
              ))}
            </ul>

            {plan.features.length > MAX_VISIBLE_FEATURES && (
              <button type="button" class="plan-card__show-more">
                <span>Ver todas las características</span>
                <svg
                  class="plan-card__show-more-icon"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  aria-hidden="true"
                >
                  <polyline points="6 9 12 15 18 9" />
                </svg>
              </button>
            )}
          </div>
        ))
      }
    </div>

  </div>
</section>

<style>
  .planes {
    padding: var(--space-2xl) 0;
    background: var(--white);
  }

  .planes__header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .planes__header .section-subtitle {
    margin-inline: auto;
  }

  /* 10. Accent font on title span */
  .planes__header .section-title span {
    font-family: var(--font-display);
    font-weight: 400;
  }

  /* 4. Toggle with sliding pill */
  .plan-toggle {
    display: inline-flex;
    position: relative;
    background: var(--cream);
    border-radius: var(--radius-full);
    padding: 4px;
    margin-top: var(--space-md);
  }

  .plan-toggle__pill {
    position: absolute;
    top: 4px;
    left: 4px;
    width: calc(50% - 4px);
    height: calc(100% - 8px);
    background: var(--olive);
    border-radius: var(--radius-full);
    box-shadow: 0 2px 10px rgba(123, 139, 62, 0.3);
    transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    z-index: 0;
  }

  .plan-toggle.usd .plan-toggle__pill {
    transform: translateX(100%);
  }

  .plan-toggle button {
    position: relative;
    z-index: 1;
    padding: 0.6rem 1.5rem;
    border-radius: var(--radius-full);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-dark);
    transition: color 0.3s ease;
  }

  .plan-toggle button.active {
    color: var(--white);
  }

  /* Grid */
  .plans-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
    margin-top: 1rem;
    align-items: stretch;
  }

  /* Mobile: horizontal scroll snap */
  @media (max-width: 639px) {
    .plans-grid {
      display: flex;
      align-items: stretch;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      gap: var(--space-sm);
      padding-top: 1.25rem;
      padding-bottom: var(--space-sm);
    }

    .plans-grid::-webkit-scrollbar {
      display: none;
    }

    .plan-card {
      min-width: 280px;
      flex: 0 0 85%;
      scroll-snap-align: center;
    }
  }

  /* Card */
  .plan-card {
    display: flex;
    flex-direction: column;
    background: var(--white);
    border: 1.5px solid var(--cream);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    position: relative;
    transition: var(--transition);
    text-align: center;
  }

  .plan-card:hover {
    border-color: var(--olive);
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.06);
  }

  /* 2. Enhanced featured card */
  .plan-card.featured {
    border-color: var(--olive);
    background: var(--white);
    box-shadow: 0 8px 30px rgba(123, 139, 62, 0.12);
  }

  .plan-card.featured:hover {
    box-shadow: 0 16px 50px rgba(123, 139, 62, 0.18);
  }

  .plan-card__badge {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translate(-50%, -50%);
    padding: 0.3rem 0.8rem;
    background: var(--olive);
    color: var(--white);
    font-size: 0.7rem;
    font-weight: 600;
    border-radius: var(--radius-full);
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  .plan-card__name {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-dark);
    margin-bottom: var(--space-md);
  }

  /* 3. Larger, more prominent price */
  .plan-card__price {
    display: flex;
    align-items: baseline;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.25rem;
    margin-bottom: var(--space-md);
  }

  .plan-card__currency {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--olive);
  }

  .plan-card__amount {
    font-size: 2.25rem;
    font-weight: 700;
    color: var(--olive);
    line-height: 1;
  }

  .plan-card__period {
    font-size: 0.85rem;
    color: var(--text-light);
  }

  /* 9. Price change animation */
  .plan-card__amount,
  .plan-card__currency {
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;
  }

  :global(.price-updating) .plan-card__amount,
  :global(.price-updating) .plan-card__currency {
    opacity: 0;
    transform: translateY(-4px);
  }

  /* 5. Features with separators */
  .plan-card__features {
    flex: 1;
    margin-bottom: var(--space-sm);
    text-align: left;
  }

  .plan-card__features li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    padding: 0.5rem 0;
    font-size: 0.9rem;
    color: var(--text-dark);
    border-bottom: 1px solid var(--cream);
  }

  .plan-card__features li:last-child {
    border-bottom: none;
  }

  .plan-card__features li svg {
    width: 18px;
    height: 18px;
    color: var(--olive);
    flex-shrink: 0;
    margin-top: 2px;
  }

  /* 6. Collapsible features — only on mobile */
  .plan-card__features li {
    overflow: hidden;
    max-height: 100px;
    transition:
      max-height 0.3s ease,
      opacity 0.3s ease,
      padding 0.3s ease;
  }

  .plan-card:not(.expanded) .plan-card__features li:nth-child(n + 6) {
    max-height: 0;
    opacity: 0;
    padding: 0;
    border-bottom: none;
  }

  .plan-card__show-more {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    margin-bottom: var(--space-md);
    padding: 0;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--olive);
    cursor: pointer;
    transition: var(--transition);
    background: none;
    border: none;
  }

  .plan-card__show-more:hover {
    color: var(--olive-dark);
  }

  .plan-card__show-more-icon {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }

  .plan-card.expanded .plan-card__show-more-icon {
    transform: rotate(180deg);
  }

  /* 1. CTA button in each card */
  .plan-card__cta {
    display: block;
    padding: 0.75rem 1.5rem;
    border: 1.5px solid var(--olive);
    border-radius: var(--radius-full);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--olive);
    text-align: center;
    text-decoration: none;
    transition: var(--transition);
    margin-bottom: var(--space-md);
  }

  .plan-card__cta:hover {
    background: var(--olive);
    color: var(--white);
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(123, 139, 62, 0.3);
  }

  /* Featured card CTA is filled */
  .plan-card__cta--featured {
    background: var(--olive);
    color: var(--white);
  }

  .plan-card__cta--featured:hover {
    background: var(--olive-dark);
  }


  /* 8. Adjusted breakpoints */
  @media (min-width: 640px) {
    .plans-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    /* Desktop: show all features, hide toggle button */
    .plan-card:not(.expanded) .plan-card__features li:nth-child(n + 6) {
      max-height: 100px;
      opacity: 1;
      padding: 0.5rem 0;
      border-bottom: 1px solid var(--cream);
    }

    .plan-card:not(.expanded) .plan-card__features li:last-child {
      border-bottom: none;
    }

    .plan-card__show-more {
      display: none;
    }
  }

  @media (min-width: 1024px) {
    .plans-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    /* 2. Scale featured card on desktop */
    .plan-card.featured {
      transform: scale(1.03);
    }

    .plan-card.featured:hover {
      transform: scale(1.03) translateY(-4px);
    }
  }

  @media (min-width: 1280px) {
    .plans-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>

<script>
  const toggle = document.querySelector(".plan-toggle");
  const toggleBtns = document.querySelectorAll(".plan-toggle button");
  const cards = document.querySelectorAll<HTMLElement>(".plan-card");

  // 4. Toggle with sliding pill
  toggleBtns.forEach((btn, index) => {
    btn.addEventListener("click", () => {
      toggleBtns.forEach((b) => {
        b.classList.remove("active");
        b.setAttribute("aria-selected", "false");
      });
      btn.classList.add("active");
      btn.setAttribute("aria-selected", "true");

      const isUsd = index === 1;

      // Update pill position
      if (isUsd) {
        toggle?.classList.add("usd");
      } else {
        toggle?.classList.remove("usd");
      }

      // 9. Animate price change
      document.body.classList.add("price-updating");

      setTimeout(() => {
        cards.forEach((card) => {
          const amount = card.querySelector(".plan-card__amount");
          const currency = card.querySelector(".plan-card__currency");
          if (amount && currency) {
            if (isUsd) {
              amount.textContent = card.dataset.priceUsd ?? "";
              currency.textContent = "USD";
            } else {
              amount.textContent = card.dataset.price ?? "";
              currency.textContent = "ARS";
            }
          }
        });

        document.body.classList.remove("price-updating");
      }, 200);
    });
  });

  // 6. Show more / show less features
  document.querySelectorAll(".plan-card__show-more").forEach((btn) => {
    const label = btn.querySelector("span");
    btn.addEventListener("click", () => {
      const card = btn.closest(".plan-card");
      if (!card || !label) return;
      const isExpanded = card.classList.toggle("expanded");
      label.textContent = isExpanded
        ? "Ver menos"
        : "Ver todas las características";
    });
  });
</script>
