---
import { servicios, whatsappNumber } from "@data/dataSite";

const MAX_REVEAL_DELAY = 4;
const whatsappBase = `https://wa.me/+${whatsappNumber}`;
---

<!-- SVG symbol reutilizable (se renderiza una sola vez) -->
<svg class="sr-only" aria-hidden="true">
  <symbol
    id="icon-check"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
  >
    <polyline points="20 6 9 17 4 12" />
  </symbol>
</svg>

<section class="servicios" id="servicios">
  <div class="container">
    <div class="servicios__header reveal">
      <span class="section-label">Nuestros servicios</span>
      <h2 class="section-title">
        Potenciá tu marca con <span>servicios a medida</span>
      </h2>
      <p class="section-subtitle">
        Elegí servicios individuales diseñados para llevar tu presencia digital
        al siguiente nivel.
      </p>
    </div>

    <div class="servicios__grid">
      {
        servicios.map((servicio, i) => {
          const delay = Math.min(i + 1, MAX_REVEAL_DELAY);
          const ctaHref = `${whatsappBase}?text=${encodeURIComponent(`Hola, me interesa el servicio de ${servicio.title}, quiero más info`)}`;

          return (
            <article
              class:list={[
                "servicio-card",
                "reveal",
                `reveal-delay-${delay}`,
              ]}
            >
              <div class="servicio-card__info">
                <h3 class="servicio-card__title">{servicio.title}</h3>
                <p class="servicio-card__desc">{servicio.description}</p>
              </div>

              <ul class="servicio-card__list">
                {servicio.items.map((item) => (
                  <li class="servicio-card__item">
                    <svg class="servicio-card__item-icon" aria-hidden="true">
                      <use href="#icon-check" />
                    </svg>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>

              <a
                href={ctaHref}
                target="_blank"
                rel="noopener noreferrer"
                class="servicio-card__cta"
              >
                Más info
              </a>
            </article>
          );
        })
      }
    </div>

    <div
      class="servicios__dots"
      role="tablist"
      aria-label="Navegar entre servicios"
    >
      {
        servicios.map((servicio, i) => (
          <button
            type="button"
            class="servicios__dot"
            data-dot-index={i}
            aria-label={`Ir al servicio ${i + 1}: ${servicio.title}`}
            aria-current={i === 0 ? "true" : "false"}
          />
        ))
      }
    </div>
  </div>
</section>

<style>
  .servicios {
    padding: var(--space-2xl) 0;
    background: var(--cream);
  }

  .servicios__header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .servicios__header .section-subtitle {
    margin-inline: auto;
  }

  .servicios__header .section-title span {
    font-family: var(--font-display);
    font-weight: 400;
  }

  /* Carrusel (mobile / tablet): grid horizontal con scroll-snap.
     grid-auto-flow: column + grid-template-rows hace que TODAS las cards
     compartan las mismas 2 pistas de fila (info / lista), de modo que los
     listados arrancan siempre en la misma línea del eje X. */
  .servicios__grid {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: 85%;
    grid-template-rows: auto auto auto;
    gap: var(--space-md);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    scroll-snap-type: x mandatory;
    padding-bottom: var(--space-sm);
  }

  .servicios__grid::-webkit-scrollbar {
    display: none;
  }

  /* Dots: solo visibles mientras el layout es carrusel */
  .servicios__dots {
    display: none;
  }

  @media (min-width: 640px) {
    .servicios__grid {
      grid-auto-columns: calc((100% - var(--space-md)) / 2);
    }
  }

  @media (max-width: 1023px) {
    /* Indicadores de posición */
    .servicios__dots {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 0.5rem;
      margin-top: var(--space-md);
    }

    .servicios__dot {
      width: 8px;
      height: 8px;
      padding: 0;
      border: none;
      border-radius: 50%;
      background: rgba(123, 139, 62, 0.3);
      cursor: pointer;
      transition:
        width 0.3s ease,
        background 0.3s ease;
    }

    .servicios__dot:hover {
      background: rgba(123, 139, 62, 0.55);
    }

    .servicios__dot[aria-current="true"] {
      width: 24px;
      border-radius: var(--radius-full);
      background: var(--olive);
    }
  }

  /* Desktop: las 4 cards visibles a la vez, sin carrusel */
  @media (min-width: 1024px) {
    .servicios__grid {
      grid-auto-flow: row;
      grid-template-columns: repeat(4, 1fr);
      overflow: visible;
      scroll-snap-type: none;
      padding-bottom: 0;
    }
  }

  /* Card */
  .servicio-card {
    display: grid;
    grid-template-rows: subgrid;
    grid-row: span 3;
    gap: var(--space-md);
    padding: var(--space-lg);
    border-radius: var(--radius-lg);
    overflow: hidden;
    position: relative;
    scroll-snap-align: start;
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
    background: var(--white);
    border: 1px solid rgba(123, 139, 62, 0.2);
  }

  .servicio-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.08);
  }

  .servicio-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at 80% 20%,
      rgba(255, 255, 255, 0.4) 0%,
      transparent 60%
    );
    pointer-events: none;
  }

  .servicio-card__info {
    position: relative;
  }

  .servicio-card__title {
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.3;
    color: var(--text-dark);
    margin-bottom: 0.5rem;
  }

  .servicio-card__desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  /* Listado de servicios */
  .servicio-card__list {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    list-style: none;
  }

  .servicio-card__item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.5rem 0;
    font-size: 0.9rem;
    color: var(--text-dark);
    border-bottom: 1px solid rgba(123, 139, 62, 0.15);
  }

  .servicio-card__item:last-child {
    border-bottom: none;
  }

  .servicio-card__item-icon {
    width: 18px;
    height: 18px;
    color: var(--olive);
    flex-shrink: 0;
  }

  /* CTA */
  .servicio-card__cta {
    position: relative;
    display: block;
    align-self: end;
    padding: 0.75rem 1.5rem;
    border: 1.5px solid var(--olive);
    border-radius: var(--radius-full);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--olive);
    text-align: center;
    text-decoration: none;
    transition:
      background 0.3s ease,
      color 0.3s ease,
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }

  .servicio-card__cta:hover {
    background: var(--olive);
    color: var(--white);
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(123, 139, 62, 0.3);
  }
</style>

<script>
  const grid = document.querySelector<HTMLElement>(".servicios__grid");

  if (grid) {
    const cards = Array.from(
      grid.querySelectorAll<HTMLElement>(".servicio-card"),
    );
    const dots = Array.from(
      document.querySelectorAll<HTMLButtonElement>(".servicios__dot"),
    );

    // Dots (carrusel): click → scroll a la card
    dots.forEach((dot, i) => {
      dot.addEventListener("click", () => {
        cards[i]?.scrollIntoView({
          behavior: "smooth",
          inline: "center",
          block: "nearest",
        });
      });
    });

    // Scroll → marca el dot de la card más visible
    if (cards.length && dots.length === cards.length) {
      const setActive = (index: number) => {
        dots.forEach((d, i) =>
          d.setAttribute("aria-current", i === index ? "true" : "false"),
        );
      };

      const observer = new IntersectionObserver(
        (entries) => {
          const visible = entries
            .filter((e) => e.isIntersecting)
            .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
          if (visible) {
            setActive(cards.indexOf(visible.target as HTMLElement));
          }
        },
        { root: grid, threshold: [0.5, 0.75, 1] },
      );

      cards.forEach((card) => observer.observe(card));
    }
  }
</script>
