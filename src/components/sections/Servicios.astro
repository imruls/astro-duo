---
import {
  servicios,
  servicioCategorias,
  whatsappNumber,
} from "@data/dataSite";

const MAX_REVEAL_DELAY = 4;
const whatsappBase = `https://wa.me/+${whatsappNumber}`;
const filtros = servicioCategorias;
const filtroInicial = filtros[0].id;
---

<!-- 1. SVG symbol reutilizable (se renderiza una sola vez) -->
<svg class="sr-only" aria-hidden="true">
  <symbol
    id="icon-info"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
  >
    <circle cx="12" cy="12" r="10" />
    <line x1="12" y1="16" x2="12" y2="12" />
    <line x1="12" y1="8" x2="12.01" y2="8" />
  </symbol>
</svg>

<section class="servicios" id="servicios">
  <div class="container">
    <div class="servicios__header reveal">
      <span class="section-label">Nuestros servicios</span>
      <h2 class="section-title">
        Potenciá tu marca con <span>servicios a medida</span>
      </h2>
      <p class="section-subtitle">
        Complementá tu plan con servicios individuales diseñados para llevar tu
        presencia digital al siguiente nivel.
      </p>
    </div>

    <div
      class="servicios__filtros reveal"
      role="tablist"
      aria-label="Filtrar servicios por categoría"
    >
      {
        filtros.map((filtro) => (
          <button
            type="button"
            role="tab"
            class="servicios__filtro"
            data-filtro={filtro.id}
            aria-pressed={filtro.id === filtroInicial ? "true" : "false"}
          >
            {filtro.label}
          </button>
        ))
      }
    </div>

    <div class="servicios__grid" data-filtro-activo={filtroInicial}>
      {
        servicios.map((servicio, i) => {
          const delay = Math.min(i + 1, MAX_REVEAL_DELAY);
          const defaultHref = `${whatsappBase}?text=${encodeURIComponent(`Hola, me interesa el servicio de ${servicio.title}, quiero más info`)}`;

          return (
            <div
              class:list={[
                "servicio-card",
                "reveal",
                `reveal-delay-${delay}`,
              ]}
              data-category={servicio.category}
            >
              <div class="servicio-card__info">
                <h4 class="servicio-card__title">{servicio.title}</h4>
                <p class="servicio-card__desc">{servicio.description}</p>
              </div>

              <div class="servicio-card__pricing">
                <div class="servicio-card__pricing-inner">
                  {servicio.price ? (
                    <>
                      <span class="servicio-card__pricing-label">
                        {servicio.pricingLabel}
                      </span>
                      <div class="servicio-card__prices">
                        <div class="servicio-card__price">
                          <span class="servicio-card__currency">ARS</span>
                          <span class="servicio-card__amount">
                            {servicio.price}
                          </span>
                        </div>
                        <span class="servicio-card__price-separator">|</span>
                        <div class="servicio-card__price">
                          <span class="servicio-card__currency">USD</span>
                          <span class="servicio-card__amount">
                            {servicio.priceUsd}
                          </span>
                        </div>
                      </div>
                    </>
                  ) : (
                    <span class="servicio-card__price-custom">
                      Cotización personalizada
                    </span>
                  )}
                </div>
              </div>

              <div class="servicio-card__note">
                <svg class="servicio-card__note-icon" aria-hidden="true">
                  <use href="#icon-info" />
                </svg>
                <p set:html={servicio.note} />
              </div>

              <a
                href={servicio.ctaHref ?? defaultHref}
                target="_blank"
                rel="noopener noreferrer"
                class="servicio-card__cta"
              >
                Consultar
              </a>
            </div>
          );
        })
      }
    </div>

    <div
      class="servicios__dots"
      role="tablist"
      aria-label="Navegar entre servicios"
    >
      {
        servicios.map((servicio, i) => (
          <button
            type="button"
            class="servicios__dot"
            data-dot-index={i}
            aria-label={`Ir al servicio ${i + 1}: ${servicio.title}`}
            aria-current={i === 0 ? "true" : "false"}
          />
        ))
      }
    </div>
  </div>
</section>

<style>
  .servicios {
    padding: var(--space-2xl) 0;
    background: var(--cream);
  }

  .servicios__header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .servicios__header .section-subtitle {
    margin-inline: auto;
  }

  .servicios__header .section-title span {
    font-family: var(--font-display);
    font-weight: 400;
  }

  /* Filtros */
  .servicios__filtros {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: var(--space-lg);
  }

  .servicios__filtro {
    padding: 0.5rem 1.1rem;
    border: 1.5px solid rgba(123, 139, 62, 0.35);
    border-radius: var(--radius-full);
    background: transparent;
    color: var(--text-dark);
    font-family: inherit;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition:
      background 0.25s ease,
      color 0.25s ease,
      border-color 0.25s ease;
  }

  .servicios__filtro:hover {
    border-color: var(--olive);
    color: var(--olive-dark);
  }

  .servicios__filtro[aria-pressed="true"] {
    background: var(--olive);
    border-color: var(--olive);
    color: var(--white);
  }

  /* Grid */
  .servicios__grid {
    display: grid;
    grid-template-columns: 1fr;
    grid-template-rows: auto;
    gap: var(--space-md);
  }

  /* Filtrado solo en desktop: en mobile se muestra el carrusel completo */
  @media (min-width: 640px) {
    .servicios__grid[data-filtro-activo="marca"]
      .servicio-card:not([data-category="marca"]),
    .servicios__grid[data-filtro-activo="contenido"]
      .servicio-card:not([data-category="contenido"]),
    .servicios__grid[data-filtro-activo="estrategia"]
      .servicio-card:not([data-category="estrategia"]) {
      display: none;
    }
  }

  /* Dots: solo visibles en mobile */
  .servicios__dots {
    display: none;
  }

  /* Mobile: carrusel horizontal con swipe */
  @media (max-width: 639px) {
    /* Ocultar filtros: el carrusel muestra todos los servicios */
    .servicios__filtros {
      display: none;
    }

    .servicios__grid {
      display: flex;
      align-items: stretch;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      gap: var(--space-sm);
      padding-bottom: var(--space-sm);
      scroll-snap-type: x mandatory;
      scroll-padding-inline: var(--space-md);
    }

    .servicios__grid::-webkit-scrollbar {
      display: none;
    }

    .servicio-card {
      min-width: 280px;
      flex: 0 0 85%;
      grid-template-rows: 1fr auto auto auto;
      scroll-snap-align: center;
    }

    /* Indicadores de posición */
    .servicios__dots {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 0.5rem;
      margin-top: var(--space-md);
    }

    .servicios__dot {
      width: 8px;
      height: 8px;
      padding: 0;
      border: none;
      border-radius: 50%;
      background: rgba(123, 139, 62, 0.3);
      cursor: pointer;
      transition:
        width 0.3s ease,
        background 0.3s ease;
    }

    .servicios__dot:hover {
      background: rgba(123, 139, 62, 0.55);
    }

    .servicios__dot[aria-current="true"] {
      width: 24px;
      border-radius: var(--radius-full);
      background: var(--olive);
    }
  }

  /* Card */
  .servicio-card {
    display: grid;
    grid-template-rows: subgrid;
    grid-row: span 4;
    gap: var(--space-sm);
    padding: var(--space-lg);
    border-radius: var(--radius-lg);
    overflow: hidden;
    position: relative;
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
    background: var(--white);
    border: 1px solid rgba(123, 139, 62, 0.2);
  }

  .servicio-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.08);
  }

  .servicio-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at 80% 20%,
      rgba(255, 255, 255, 0.4) 0%,
      transparent 60%
    );
    pointer-events: none;
  }

  .servicio-card__info {
    position: relative;
  }

  .servicio-card__title {
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.3;
    color: var(--text-dark);
    margin-bottom: 0.35rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    /* 2 líneas: 1.25rem * 1.3 = 3.25rem */
    min-height: calc(1.25rem * 1.3 * 2);
  }

  .servicio-card__desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    /* 3 líneas: 0.9rem * 1.6 * 3 = 4.32rem */
    min-height: calc(0.9rem * 1.6 * 3);
  }

  .servicio-card__pricing {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .servicio-card__pricing-inner {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 0.25rem;
    padding-top: var(--space-sm);
    border-top: 1px solid rgba(0, 0, 0, 0.08);
    min-height: 4rem;
  }

  .servicio-card__price-custom {
    font-size: 1rem;
    font-weight: 600;
    font-style: italic;
    color: var(--text-muted);
    text-align: center;
  }

  .servicio-card__pricing-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
  }

  .servicio-card__prices {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .servicio-card__price {
    display: flex;
    align-items: baseline;
    gap: 0.35rem;
  }

  .servicio-card__price-separator {
    font-size: 1.25rem;
    color: var(--text-muted);
    font-weight: 300;
  }

  .servicio-card__currency {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--olive-dark);
  }

  .servicio-card__amount {
    font-size: 1.75rem;
    font-weight: 700;
    line-height: 1;
    color: var(--olive-dark);
  }

  .servicio-card__note {
    position: relative;
    display: flex;
    align-items: flex-start;
    align-self: start;
    gap: 0.5rem;
    padding: 0.6rem 0.75rem;
    background: rgba(123, 139, 62, 0.08);
    border-radius: var(--radius-sm);
    border-left: 2px solid var(--olive);
  }

  .servicio-card__note-icon {
    width: 16px;
    height: 16px;
    color: var(--olive);
    flex-shrink: 0;
    margin-top: 1px;
  }

  .servicio-card__note p {
    font-size: 0.85rem;
    color: var(--text-dark);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    /* 2 líneas: 0.85rem * 1.5 * 2 = 2.55rem */
    min-height: calc(0.85rem * 1.5 * 2);
  }

  .servicio-card__note :global(strong) {
    font-weight: 600;
  }

  .servicio-card__cta {
    position: relative;
    display: block;
    align-self: end;
    padding: 0.75rem 1.5rem;
    border: 1.5px solid var(--olive);
    border-radius: var(--radius-full);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--olive);
    text-align: center;
    text-decoration: none;
    transition:
      background 0.3s ease,
      color 0.3s ease,
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }

  .servicio-card__cta:hover {
    background: var(--olive);
    color: var(--white);
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(123, 139, 62, 0.3);
  }

  @media (min-width: 768px) {
    .servicios__grid {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: repeat(auto-fill, auto);
    }
  }

  @media (min-width: 1280px) {
    .servicios__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>

<script>
  const grid = document.querySelector<HTMLElement>(".servicios__grid");
  const botones = document.querySelectorAll<HTMLButtonElement>(
    ".servicios__filtro",
  );

  // Filtros (desktop)
  if (grid && botones.length) {
    botones.forEach((btn) => {
      btn.addEventListener("click", () => {
        const filtro = btn.dataset.filtro ?? "todos";
        grid.dataset.filtroActivo = filtro;
        botones.forEach((b) =>
          b.setAttribute("aria-pressed", b === btn ? "true" : "false"),
        );
      });
    });
  }

  // Dots del carrusel mobile: sync con scroll + nav directa
  const mobileMQ = window.matchMedia("(max-width: 639px)");

  if (grid && mobileMQ.matches) {
    const cards = Array.from(
      grid.querySelectorAll<HTMLElement>(".servicio-card"),
    );
    const dots = Array.from(
      document.querySelectorAll<HTMLButtonElement>(".servicios__dot"),
    );

    if (cards.length && dots.length === cards.length) {
      // Click en dot → scroll a la card correspondiente
      dots.forEach((dot, i) => {
        dot.addEventListener("click", () => {
          cards[i].scrollIntoView({
            behavior: "smooth",
            inline: "center",
            block: "nearest",
          });
        });
      });

      // Scroll → marca el dot de la card más visible
      const setActive = (index: number) => {
        dots.forEach((d, i) =>
          d.setAttribute("aria-current", i === index ? "true" : "false"),
        );
      };

      const observer = new IntersectionObserver(
        (entries) => {
          // Card con mayor intersection ratio = la activa
          const visible = entries
            .filter((e) => e.isIntersecting)
            .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
          if (visible) {
            setActive(cards.indexOf(visible.target as HTMLElement));
          }
        },
        { root: grid, threshold: [0.5, 0.75, 1] },
      );

      cards.forEach((card) => observer.observe(card));
    }
  }
</script>
