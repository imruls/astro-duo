---
type IconName =
  | "book"
  | "chart"
  | "rocket"
  | "info"
  | "download"
  | "chevron-left"
  | "chevron-right"
  | "star";

interface Props {
  name: IconName;
  size?: number;
  fill?: string;
  stroke?: string;
}

const { name, size = 18, fill = "none", stroke = "currentColor" } = Astro.props;

const icons: Record<IconName, string> = {
  book: '<path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/>',
  chart: '<path d="M12 20V10M18 20V4M6 20v-4"/>',
  rocket:
    '<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 00-2.91-.09z"/><path d="M12 15l-3-3a22 22 0 012-3.95A12.88 12.88 0 0122 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 01-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>',
  info: '<circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/>',
  download:
    '<path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/>',
  "chevron-left": '<path d="M15 18l-6-6 6-6"/>',
  "chevron-right": '<path d="M9 18l6-6-6-6"/>',
  star: '<path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>',
};
---

<svg
  viewBox="0 0 24 24"
  fill={fill}
  stroke={stroke}
  stroke-width="2"
  width={size}
  height={size}
  aria-hidden="true"
  set:html={icons[name]}
/>
