---
import "../styles/global.css";
import "@fontsource/poppins/300.css";
import "@fontsource/poppins/400.css";
import "@fontsource/poppins/500.css";
import "@fontsource/poppins/600.css";
import "@fontsource/poppins/700.css";
import "@fontsource/pacifico/400.css";

interface Props {
  title?: string;
  description?: string;
}

const siteUrl = "https://duostudiodigital.com.ar";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;

const {
  title = "Dúo Studio Digital — Agencia de Marketing",
  description = "Dúo Studio Digital es una agencia de marketing digital que impulsa tu marca con estrategia, creatividad y resultados.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Hreflang -->
    <link rel="alternate" hreflang="es-AR" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon-512.png" />
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="apple-touch-icon" href="/favicon-192.png" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_AR" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={`${siteUrl}/og-image.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Dúo Studio Digital" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}/og-image.png`} />

    <!-- JSON-LD Structured Data -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "MarketingAgency",
        name: "Dúo Studio Digital",
        description: description,
        url: siteUrl,
        logo: `${siteUrl}/favicon-512.png`,
        address: {
          "@type": "PostalAddress",
          addressLocality: "Buenos Aires",
          addressCountry: "AR",
        },
        contactPoint: {
          "@type": "ContactPoint",
          email: "contacto@duostudiodigital.com",
          contactType: "customer service",
        },
        sameAs: [
          "https://www.instagram.com/duostudio.digital/",
          "https://www.tiktok.com/@duo.studio.digital",
        ],
      })}
    />

    <!-- JSON-LD Service Schema -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "ItemList",
        itemListElement: [
          {
            "@type": "ListItem",
            position: 1,
            item: {
              "@type": "Service",
              name: "Community Management",
              description:
                "Gestión de redes sociales con publicaciones, historias, diseño gráfico, copywriting y reportes de métricas.",
              provider: {
                "@type": "Organization",
                name: "Dúo Studio Digital",
              },
              areaServed: {
                "@type": "Country",
                name: "Argentina",
              },
            },
          },
          {
            "@type": "ListItem",
            position: 2,
            item: {
              "@type": "Service",
              name: "Campañas + Paid Media",
              description:
                "Gestión de campañas publicitarias: estrategia, segmentación, creatividades y optimización continua.",
              provider: {
                "@type": "Organization",
                name: "Dúo Studio Digital",
              },
              areaServed: {
                "@type": "Country",
                name: "Argentina",
              },
            },
          },
          {
            "@type": "ListItem",
            position: 3,
            item: {
              "@type": "Service",
              name: "Grabación de Contenido",
              description:
                "Producción de contenido visual profesional: fotos, reels y videos con dirección creativa y edición incluida.",
              provider: {
                "@type": "Organization",
                name: "Dúo Studio Digital",
              },
              areaServed: {
                "@type": "Country",
                name: "Argentina",
              },
            },
          },
        ],
      })}
    />

    <title>{title}</title>
  </head>

  <body>
    <slot />

    <!-- Reveal observer -->
    <script>
      const revealElements = document.querySelectorAll(".reveal");
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: "0px 0px -50px 0px" },
      );
      revealElements.forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
