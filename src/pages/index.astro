---
/**
 * index.astro — Home page
 * Composes all section components inside the base layout.
 * Each component is self-contained (markup + scoped styles + script).
 */
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import Planes from "../components/Planes.astro";
import Ebook from "../components/Ebook.astro";
import Recursos from "../components/Recursos.astro";
import About from "../components/About.astro";
import Footer from "../components/Footer.astro";
import BotonFlotante from "../components/BotonFlotante.astro";
---

<Layout>
  <Navbar />
  <main>
    <Hero />
    <Planes />
    <Ebook />
    <Recursos />
    <About />
  </main>
  <Footer />
  <BotonFlotante whatsappUrl="https://wa.me/" />
</Layout>
